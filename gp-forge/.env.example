# GP Forge — Phase-1 configuration (copy to .env and edit). NO real patient data until DPIA + DCB0160 signed.

# Practice-facing API
GPF_PORT=8089
# Client auth: comma-separated key:actor pairs (one virtual key per clinician; never a shared god-key in prod)
GPF_API_KEYS=dev-key-alice:alice,dev-key-bob:bob

# Local LLM backend (OpenAI-compatible — LiteLLM gateway in front of Ollama/vLLM)
GPF_LLM_BASE_URL=http://localhost:4000/v1
GPF_LLM_API_KEY=sk-litellm-local
GPF_MODEL=qwen3-30b
GPF_LLM_TIMEOUT_MS=30000

# Audit (append-only, hash-chained). Default stores HASHES of content, not raw PHI.
GPF_AUDIT_PATH=./data/audit.jsonl
GPF_AUDIT_STORE_CONTENT=false

# Fail-closed egress control. The appliance must NOT reach the internet beyond the allow-listed
# Medicus host. On startup GP Forge probes a canary external host; if it is reachable, egress is
# NOT locked and GP Forge refuses to start (fail-closed). Set GPF_ALLOW_OPEN_EGRESS=true ONLY for
# local dev with MOCK data — it disables the hard fail and logs a loud warning.
GPF_EGRESS_CANARY_HOST=1.1.1.1
GPF_EGRESS_CANARY_PORT=443
GPF_ALLOW_OPEN_EGRESS=false

# Optional local speech-to-text (faster-whisper, OpenAI-compatible). Leave GPF_STT_BASE_URL empty to
# disable transcription. PHASE 1 = VERBATIM transcripts only (verified by the clinician) — NOT a
# generative clinical summary (that would be a Phase-2 medical device).
GPF_STT_BASE_URL=
GPF_STT_API_KEY=
GPF_STT_MODEL=whisper-1
GPF_STT_TIMEOUT_MS=60000
